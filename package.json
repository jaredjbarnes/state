{
  "name": "@jjb/state",
  "version": "0.1.0",
  "description": "Reactive state primitives — Signals, Runners, Broadcasts — with optional React bindings.",
  "license": "(Apache-2.0 AND MIT)",
  "author": "Jared J Barnes",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "vite build",
    "check:types": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run check:types && npm run test:run && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaredjbarnes/state.git"
  },
  "homepage": "https://github.com/jaredjbarnes/state#readme",
  "bugs": {
    "url": "https://github.com/jaredjbarnes/state/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "signal",
    "signals",
    "state",
    "reactive",
    "broadcast",
    "subscription",
    "react",
    "hooks"
  ],
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0",
    "vitest": "^2.1.9"
  }
}
